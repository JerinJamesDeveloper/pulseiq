# copy this file to .env and fill in the values

# database configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password
DB_NAME=pulseiq
DB_PORT=3306
DB_CONNECTION_LIMIT=10

# CORS origin (optional)
CORS_ORIGIN=http://localhost:5173

# OpenRouter AI configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
# optional, default is gpt-4o-mini
OPENROUTER_MODEL=gpt-4o-mini
# optional, default is https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# GitHub API token (optional but recommended to avoid strict rate limits)
GITHUB_TOKEN=ghp_your_token_here

# Dev-only: disable TLS cert verification (use only in local debugging)
DEV_INSECURE_TLS=false
